<Window x:Class="S1200_STATION4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:S1200_STATION4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!-- 主界面容器 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" MinHeight="60" />
            <RowDefinition Height="Auto" MinHeight="140" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 连接状态指示灯 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" Width="98" >
            <Ellipse Width="40" Height="40" Name="ConnectionStatusLight" Fill="Red"  />
            <TextBlock Text="连接状态" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- 连接与断开按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10" Width="388">
            <TextBlock Text="IP地址:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Name="IpAddressTextBox" Text="192.168.0.4" Width="120" VerticalContentAlignment="Center" Margin="0,0,15,0" />
            <Button Content="连接PLC" Name="ConnectButton" Width="100" Height="40" Click="ConnectButton_ClickAsync" Margin="0,0,10,0" />
            <Button Content="断开连接" Name="DisconnectButton" Width="100" Height="40" Click="DisconnectButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10" Width="500">
            <TextBlock Name="ResultText" Background="#cacaca" Height="120" Width="500" Padding="10" FontSize="14" Text="" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Width="Auto">
            <Button Content="改变指示灯状态" Width="100" Height="40" Click="FB_ChangeLight_Click" Margin="0,0,10,0" />
            <Button Content="获取高度" Width="100" Height="40" Margin="0,0,10,0" Click="Button_Click" />
            <Button Content="系统运行" Width="100" Height="40" Click="FB_SystemRun_Click" Margin="0,0,10,0" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Width="200" Margin="0,10,0,0">
            <TextBlock Width="Auto" Height="Auto" Text="物料高度：" Background="AliceBlue" />
            <TextBox Name="ObservationValue" Height="20" Text="-1" Width="100" TextChanged="ObservationValue_TextChanged" />
        </StackPanel>

    </Grid>
</Window>
